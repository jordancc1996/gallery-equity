---
const cards = [
  {
    image: "https://images.unsplash.com/photo-1578301978018-3005759f48f7?w=800&q=80",
    category: "Art Finance",
    title: "The Illiquidity Premium: Why Art Outperforms in Private Markets",
    date: "March 1, 2025",
    href: "#",
  },
  {
    image: "https://images.unsplash.com/photo-1499781350541-7783f6c6a0c8?w=800&q=80",
    category: "Market Insight",
    title: "Understanding Loan-to-Value in Fine Art Lending",
    date: "February 15, 2025",
    href: "#",
  },
  {
    image: "https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=800&q=80",
    category: "Collection Strategy",
    title: "How Family Offices Are Rethinking Art as Capital",
    date: "February 1, 2025",
    href: "#",
  },
];
---

<section
  id="insights"
  class="py-[72px] md:py-[120px] px-6 md:px-8 bg-[var(--color-surface)]"
  aria-labelledby="insights-heading"
>
  <div class="max-w-[1200px] mx-auto">
    <header class="text-center mb-12 md:mb-16" data-animate>
      <div class="w-12 h-px bg-[var(--color-gold)] mx-auto mb-4"></div>
      <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-gold)] mb-2">
        From the Desk
      </p>
      <h2
        id="insights-heading"
        class="font-heading font-normal text-[32px] md:text-[48px] tracking-[-0.01em] text-[var(--color-accent)]"
      >
        Insights on Art & Capital
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {cards.map((card, i) => (
        <a
          href={card.href}
          class="block bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-gold)] transition-colors duration-200 no-underline group"
          data-animate
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="aspect-video overflow-hidden">
            <img
              src={card.image}
              alt=""
              width={800}
              height={450}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-7">
            <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-gold)] mb-2">
              {card.category}
            </p>
            <h3 class="font-heading font-medium text-[24px] text-[var(--color-accent)] mb-2 group-hover:text-[var(--color-gold)] transition-colors">
              {card.title}
            </h3>
            <p class="text-xs text-[var(--color-ink-muted)] mb-3">
              {card.date}
            </p>
            <span class="text-xs text-[var(--color-gold)] no-underline group-hover:underline">
              Read More →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
