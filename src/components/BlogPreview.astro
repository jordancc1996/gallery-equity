---
import { insights } from "../data/insights";

const cards = insights.map((insight) => ({
  image: insight.image,
  category: insight.category,
  title: insight.title,
  date: insight.date,
  href: `/insights/${insight.slug}`,
}));
---

<section
  id="insights"
  class="py-[72px] md:py-[120px] px-6 md:px-8 bg-[var(--color-surface)]"
  aria-labelledby="insights-heading"
>
  <div class="max-w-[1200px] mx-auto">
    <header class="text-center mb-12 md:mb-16" data-animate>
      <div class="w-12 h-px bg-[var(--color-black)] mx-auto mb-4"></div>
      <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-ink-muted)] mb-2 font-sans">
        From the Desk
      </p>
      <h2
        id="insights-heading"
        class="font-heading font-normal text-[32px] md:text-[48px] tracking-[-0.01em] text-[var(--color-accent)]"
      >
        Insights on Art & Capital
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {cards.map((card, i) => (
        <a
          href={card.href}
          class="block no-underline group border-b border-[var(--color-border)] pb-8"
          data-animate
        >
          <div class="aspect-video overflow-hidden mb-5">
            <img
              src={card.image}
              alt=""
              width={800}
              height={450}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-ink-muted)] mb-2 font-sans">
            {card.category}
          </p>
          <h3 class="font-heading font-normal text-[22px] text-[var(--color-accent)] mb-2">
            {card.title}
          </h3>
          <p class="text-[13px] text-[var(--color-ink-muted)] mb-3 font-body">
            {card.date}
          </p>
          <span class="text-[13px] text-[var(--color-black)] font-body group-hover:underline">
            Read more
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
