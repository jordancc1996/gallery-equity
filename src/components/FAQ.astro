---
const faqItems = [
  {
    q: "What types of art qualify for equity financing?",
    a: "We work with fine art across categories including modern and contemporary painting, sculpture, and works on paper. Each piece is assessed individually for authentication, provenance, and market depth.",
  },
  {
    q: "What is the minimum collection value to apply?",
    a: "Gallery Equity typically works with collectors whose aggregate art holdings are valued at $1M or above. Exceptions may be considered for single high-value works.",
  },
  {
    q: "Do I need to relinquish possession of my artwork?",
    a: "No. In most structures, the artwork remains in your possession. Specific arrangements depend on the solution and jurisdiction.",
  },
  {
    q: "How is my art valued for equity purposes?",
    a: "Valuations are conducted by independent, qualified appraisers with expertise in the relevant market. We use conservative methodologies aligned with institutional lending standards.",
  },
  {
    q: "What are the typical loan-to-value ratios?",
    a: "LTV ratios vary by asset type, concentration, and structure. We will provide indicative ranges during an initial conversation.",
  },
  {
    q: "Is this service available internationally?",
    a: "We serve collectors in select jurisdictions. Availability depends on regulatory and structuring considerations. Inquire to confirm eligibility.",
  },
  {
    q: "How long does the process typically take?",
    a: "From initial inquiry to term sheet, the process often takes several weeks, depending on collection size and complexity.",
  },
  {
    q: "Is my inquiry kept confidential?",
    a: "Yes. All inquiries are handled in strict confidence. We do not disclose client information or collection details to third parties.",
  },
];
---

<section
  id="faq"
  class="py-[72px] md:py-[120px] px-6 md:px-8 bg-[var(--color-bg)]"
  aria-labelledby="faq-heading"
>
  <div class="max-w-[800px] mx-auto" data-animate>
    <div class="w-12 h-px bg-[var(--color-gold)] mb-4"></div>
    <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-gold)] mb-2">
      Common Questions
    </p>
    <h2
      id="faq-heading"
      class="font-heading font-normal text-[32px] md:text-[48px] tracking-[-0.01em] text-[var(--color-accent)] mb-4"
    >
      Everything You Need to Know
    </h2>
    <p class="text-[var(--color-ink-muted)] text-base font-light mb-12 max-w-[680px]">
      Answers to the questions we hear most often from collectors exploring art-backed solutions.
    </p>

    <div class="border-t border-[var(--color-border)]">
      {faqItems.map((item, i) => (
        <details
          class="faq-item border-b border-[var(--color-border)] group"
          data-faq-details
        >
          <summary class="list-none cursor-pointer py-6 flex items-start justify-between gap-4">
            <span class="font-heading font-normal text-[19px] md:text-[22px] text-[var(--color-accent)] pr-8">
              {item.q}
            </span>
            <span
              class="faq-toggle flex-shrink-0 text-[20px] text-[var(--color-gold)] w-6 h-6 flex items-center justify-center"
              aria-hidden="true"
            >
              <span class="faq-plus">+</span>
              <span class="faq-minus hidden">×</span>
            </span>
          </summary>
          <div class="faq-content pb-6">
            <p class="text-[15px] font-light text-[var(--color-ink)] leading-relaxed pr-8">
              {item.a}
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 300ms ease;
  }
  .faq-item[open] .faq-content {
    /* max-height set by script for smooth animation */
  }
  .faq-item[open] .faq-plus {
    display: none;
  }
  .faq-item[open] .faq-minus {
    display: block !important;
  }
</style>

<script>
  document.querySelectorAll("[data-faq-details]").forEach((details) => {
    const content = details.querySelector(".faq-content");
    if (!content) return;
    details.addEventListener("toggle", () => {
      if (details.open) {
        content.style.maxHeight = content.scrollHeight + "px";
      } else {
        content.style.maxHeight = "0";
      }
    });
  });
</script>
