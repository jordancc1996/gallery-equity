---
const footerLinks = [
  { href: "#about", label: "About" },
  { href: "#how-it-works", label: "How It Works" },
  { href: "#insights", label: "Insights" },
  { href: "#faq", label: "FAQ" },
];
---

<footer class="py-12 md:py-16 px-6 md:px-8 bg-[var(--color-bg)] border-t border-[var(--color-border)]">
  <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <a
      href="#"
      class="font-heading font-normal text-[22px] text-[var(--color-accent)] no-underline"
    >
      Gallery Equity
    </a>
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap items-center justify-center gap-6 md:gap-8 list-none m-0 p-0">
        {footerLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-xs uppercase tracking-[0.08em] font-medium text-[var(--color-ink-muted)] no-underline hover:text-[var(--color-accent)] transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="max-w-[1200px] mx-auto mt-8 pt-8 border-t border-[var(--color-border)] text-center">
    <p class="text-[13px] text-[var(--color-ink-muted)] m-0">
      © {new Date().getFullYear()} Gallery Equity. All rights reserved.
    </p>
    <p class="text-[12px] text-[var(--color-ink-muted)] mt-2 m-0">
      Confidential inquiries only. By appointment.
    </p>
  </div>
</footer>
