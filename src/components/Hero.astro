---
const heroImageUrl =
  "https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=1200&q=85";
---

<section class="min-h-screen flex flex-col md:flex-row" aria-label="Hero">
  <div
    class="flex-1 flex items-center bg-[var(--color-bg)] pl-6 pr-6 md:pl-20 pt-24 pb-12 md:pt-0 md:pb-0 md:pr-12"
  >
    <div class="max-w-[520px] w-full">
      <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--color-gold)] mb-5 font-sans">
        Art Finance — Private Access
      </p>
      <h1 class="font-heading font-normal text-[38px] md:text-[64px] leading-[1.15] tracking-[-0.01em] text-[var(--color-accent)] mb-6">
        Your Collection. Unlocked.
      </h1>
      <p class="font-body text-[17px] text-[var(--color-ink)] mb-10 max-w-[480px] leading-relaxed">
        Gallery Equity provides discreet, flexible equity solutions for
        high-value art collections — without requiring a sale.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 mb-10">
        <a
          href="#contact"
          class="inline-block text-center py-3.5 px-8 text-white text-[12px] uppercase tracking-[0.12em] font-medium no-underline bg-[var(--color-gold)] hover:bg-[var(--color-gold-hover)] font-sans border border-[var(--color-gold)]"
        >
          Request Access
        </a>
        <a
          href="#how-it-works"
          class="inline-block text-center py-3.5 px-8 text-[12px] uppercase tracking-[0.12em] font-medium no-underline border border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white font-sans"
        >
          How It Works
        </a>
      </div>
      <p class="text-[13px] text-[var(--color-ink-muted)] font-body">
        Serving collectors with portfolios from $1M+
      </p>
    </div>
  </div>
  <div class="hero-image-wrap w-full md:w-1/2 h-[60vw] md:h-screen flex-shrink-0 relative">
    <img
      src={heroImageUrl}
      alt="Gallery interior"
      width={1200}
      height={800}
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-image-fade" aria-hidden="true"></div>
  </div>
</section>

<style>
  .hero-image-wrap {
    isolation: isolate;
  }
  .hero-image-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(245, 243, 238, 0.85) 0%,
      rgba(245, 243, 238, 0.4) 25%,
      transparent 50%
    );
    pointer-events: none;
  }
</style>
