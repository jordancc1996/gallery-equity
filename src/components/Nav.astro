---
const navLinks = [
  { href: '/#about', label: 'About', title: 'Learn about Gallery Equity and art finance solutions' },
  { href: '/#how-it-works', label: 'How It Works', title: 'How Gallery Equity art equity and financing works' },
  { href: '/#insights', label: 'Insights', title: 'Insights on art and capital from Gallery Equity' },
  { href: '/#faq', label: 'FAQ', title: 'Frequently asked questions about art equity financing' },
];
---

<nav
  id="main-nav"
  class="nav-blend fixed top-0 left-0 right-0 z-50 h-[72px] flex items-center justify-between px-6 md:px-8 transition-[background-color,border-color] duration-200"
  aria-label="Main navigation"
>
  <a
    href="/"
    title="Gallery Equity — Art Finance & Equity Solutions for Collectors"
    class="font-sans font-semibold text-[20px] md:text-[22px] tracking-[0.02em] text-[var(--color-accent)] no-underline nav-wordmark"
  >
    Gallery Equity
  </a>

  <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          title={link.title}
          class="nav-link text-sm uppercase tracking-[0.1em] font-semibold text-[var(--color-ink-muted)] no-underline hover:text-[var(--color-gold)] font-sans pb-0.5 border-b-2 border-transparent hover:border-[var(--color-gold)] transition-colors duration-200"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="flex items-center gap-4">
    <a
      href="/#contact"
      title="Request access to Gallery Equity art finance solutions"
      class="nav-cta hidden md:inline-block py-3 px-6 text-white text-[12px] uppercase tracking-[0.12em] font-semibold no-underline bg-[var(--color-gold)] hover:bg-[var(--color-gold-hover)] font-sans border border-[var(--color-gold)]"
    >
      Request Access
    </a>
    <button
      type="button"
      id="nav-toggle"
      class="md:hidden w-5 h-5 flex flex-col justify-center gap-1.5 p-0 border-0 bg-transparent cursor-pointer text-[var(--color-accent)]"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="block w-5 h-px bg-current" aria-hidden="true"></span>
      <span class="block w-5 h-px bg-current" aria-hidden="true"></span>
      <span class="block w-5 h-px bg-current" aria-hidden="true"></span>
    </button>
  </div>
</nav>

<!-- Mobile overlay menu -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-40 bg-[var(--color-accent)] opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center"
  aria-hidden="true"
>
  <ul class="flex flex-col items-center gap-8 list-none m-0 p-0">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          title={link.title}
          class="nav-overlay-link font-heading text-4xl text-white no-underline"
          data-close-overlay
        >
          {link.label}
        </a>
      </li>
    ))}
    <li>
      <a
        href="/#contact"
        title="Request access to Gallery Equity"
        class="nav-overlay-link font-heading text-4xl text-white no-underline"
        data-close-overlay
      >
        Request Access
      </a>
    </li>
  </ul>
</div>

<style>
  .nav-blend.scrolled {
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .nav-blend.scrolled .nav-wordmark,
  .nav-blend.scrolled .nav-link {
    text-shadow: none;
  }
  .nav-wordmark {
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
  }
  .nav-link {
    text-shadow: 0 0 16px rgba(255, 255, 255, 0.35);
  }
  .nav-cta {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
  }
  #nav-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const toggle = document.getElementById('nav-toggle');
  const overlay = document.getElementById('nav-overlay');

  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    });
  }

  function openMenu() {
    if (overlay && toggle) {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-label', 'Close menu');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeMenu() {
    if (overlay && toggle) {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-label', 'Open menu');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
  }

  toggle?.addEventListener('click', () => {
    if (overlay?.classList.contains('is-open')) closeMenu();
    else openMenu();
  });

  document.querySelectorAll('[data-close-overlay]').forEach((el) => {
    el.addEventListener('click', closeMenu);
  });
</script>
