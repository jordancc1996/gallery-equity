---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { insights, getInsightBySlug } from "../../data/insights";

export function getStaticPaths() {
  return insights.map((insight) => ({
    params: { slug: insight.slug },
    props: { insight },
  }));
}

const { insight } = Astro.props;
---

<BaseLayout
  title={`${insight.title} — Gallery Equity`}
  description={insight.description}
  canonicalUrl={`https://www.galleryequity.com/insights/${insight.slug}`}
>
  <Nav />
  <main class="min-h-screen bg-[var(--color-bg)]">
    <article class="max-w-[720px] mx-auto px-6 md:px-8 pt-24 md:pt-32 pb-20 md:pb-28">
      <a
        href="/#insights"
        title="Back to Insights on Art & Capital"
        class="inline-block text-[12px] uppercase tracking-[0.1em] text-[var(--color-gold)] font-sans mb-8 no-underline hover:underline"
      >
        ← Insights
      </a>
      <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-gold)] mb-4 font-sans">
        {insight.category}
      </p>
      <h1 class="font-heading font-normal text-[32px] md:text-[42px] leading-tight text-[var(--color-accent)] mb-4">
        {insight.title}
      </h1>
      <p class="font-body text-[15px] text-[var(--color-ink-muted)] mb-10">
        {insight.date}
      </p>
      <div class="aspect-video w-full overflow-hidden mb-12">
        <img
          src={insight.image}
          alt=""
          width={800}
          height={450}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="font-body text-[17px] text-[var(--color-ink)] leading-relaxed space-y-6">
        {insight.body.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <p class="mt-12 pt-8 border-t border-[var(--color-border)]">
        <a
          href="/#insights"
          title="Back to Insights on Art & Capital"
          class="text-[13px] text-[var(--color-gold)] font-body no-underline hover:underline"
        >
          ← Back to Insights
        </a>
      </p>
    </article>
  </main>
  <Footer />
</BaseLayout>
